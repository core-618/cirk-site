---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- NAV -->
  <nav>
    <div class="nav-inner">
      <span class="nav-logo mono">CIRK</span>
      <div class="nav-links">
        <a href="#model">Model</a>
        <a href="#why">Why</a>
        <a href="#execution">Execution</a>
        <a href="#examples">Examples</a>
        <a href="https://github.com/core-618/cirk" target="_blank" rel="noopener">GitHub →</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-status mono">
        <span class="hero-status-dot"></span>
        YOU HAVE 0 OPEN COMPLIANCE EVENTS
      </div>
      <h1>CIRK — Execution Model<br />for AI-Native Development.</h1>
      <p class="hero-clarify">Replace story points with Context, Iteration, Review, and Risk.</p>
      <div class="hero-cta">
        <a href="#model" class="btn-primary">Read the spec</a>
        <a href="#examples" class="btn-ghost">View examples</a>
        <a href="https://github.com/core-618/cirk" class="btn-ghost" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </section>

  <!-- THE SHIFT -->
  <section class="section alt-section" id="why">
    <div class="container narrow">
      <p class="label mono">The shift</p>
      <h2>Story points were built to estimate human effort.</h2>
      <p class="shift-sub">But AI changed the bottleneck. What matters now is not just how long work takes. It is:</p>
      <ul class="shift-list">
        <li>how much context an agent needs</li>
        <li>how many iterations are likely</li>
        <li>how much human review is required</li>
        <li>how risky rollout will be</li>
      </ul>
      <p class="shift-close">CIRK models that reality.</p>
    </div>
  </section>

  <!-- THE MODEL -->
  <section class="section" id="model">
    <div class="container">
      <p class="label mono">The model</p>
      <h2>Four dimensions. One execution policy.</h2>
      <p class="section-sub">Each task is scored from 1 to 3 across four dimensions. The vector defines how it runs.</p>

      <div class="model-formula mono">[ C, I, R, K ] → Execution Decision</div>

      <div class="dimensions-grid">
        <div class="dim-card">
          <div class="dim-letter accent">C</div>
          <h3>Context</h3>
          <p>How much system understanding does the agent need?</p>
          <table>
            <tr><td class="score mono">C1</td><td>Isolated logic, minimal context</td></tr>
            <tr><td class="score mono">C2</td><td>Multiple components, pattern awareness</td></tr>
            <tr><td class="score mono">C3</td><td>Cross-system or architectural understanding</td></tr>
          </table>
        </div>

        <div class="dim-card">
          <div class="dim-letter" style="color: var(--green)">I</div>
          <h3>Iteration</h3>
          <p>How likely is convergence to require multiple attempts?</p>
          <table>
            <tr><td class="score mono">I1</td><td>Deterministic, one pass</td></tr>
            <tr><td class="score mono">I2</td><td>Some iteration (2–3 cycles)</td></tr>
            <tr><td class="score mono">I3</td><td>High ambiguity or complexity</td></tr>
          </table>
        </div>

        <div class="dim-card">
          <div class="dim-letter" style="color: var(--amber)">R</div>
          <h3>Review</h3>
          <p>How much human validation is required?</p>
          <table>
            <tr><td class="score mono">R1</td><td>Quick validation</td></tr>
            <tr><td class="score mono">R2</td><td>Rule-level validation</td></tr>
            <tr><td class="score mono">R3</td><td>Deep architectural or critical review</td></tr>
          </table>
        </div>

        <div class="dim-card">
          <div class="dim-letter" style="color: var(--purple)">K</div>
          <h3>Integration Risk</h3>
          <p>How complex or sensitive is deployment?</p>
          <table>
            <tr><td class="score mono">K1</td><td>Safe, additive</td></tr>
            <tr><td class="score mono">K2</td><td>Modifies existing behavior</td></tr>
            <tr><td class="score mono">K3</td><td>Coordinated rollout or migration</td></tr>
          </table>
        </div>
      </div>

      <!-- Score table -->
      <div class="score-table-wrap">
        <p class="label mono">Composite score = C + I + R + K</p>
        <div class="score-table">
          <div class="score-row">
            <span class="mono score-range">4–5</span>
            <span class="badge trivial">Trivial</span>
            <span class="score-note">Autonomous execution — no human intervention needed</span>
          </div>
          <div class="score-row">
            <span class="mono score-range">6–7</span>
            <span class="badge simple">Simple</span>
            <span class="score-note">Guided execution — human review before merge</span>
          </div>
          <div class="score-row">
            <span class="mono score-range">8–9</span>
            <span class="badge medium">Medium</span>
            <span class="score-note">Draft-first or guided — no auto-merge</span>
          </div>
          <div class="score-row">
            <span class="mono score-range">10–11</span>
            <span class="badge complex">Complex</span>
            <span class="score-note">Supervised — approval per step, deploy plan required</span>
          </div>
          <div class="score-row">
            <span class="mono score-range">12</span>
            <span class="badge split">Split Required</span>
            <span class="score-note">Execution blocked — task must be decomposed first</span>
          </div>
        </div>
        <p class="score-note-footer">The vector matters more than the score. Two tasks with the same total may require completely different execution policies.</p>
      </div>

      <div class="inline-example">
        <p class="label mono">Example — Login API</p>
        <div class="inline-ex-vector mono">C2 I2 R3 K1 <span class="inline-ex-score">→ Score 8</span></div>
        <div class="inline-ex-rules">
          <span class="ex-b-item ok">✓ Agent can prepare implementation</span>
          <span class="ex-b-item warn">⚠ Human review is mandatory</span>
          <span class="ex-b-item warn">⚠ Auto-merge is disabled</span>
        </div>
      </div>

    </div>
  </section>

  <!-- HOW TO USE -->
  <section class="section alt-section">
    <div class="container narrow">
      <p class="label mono">How to use</p>
      <h2>Three steps.</h2>
      <div class="steps">
        <div class="step">
          <div class="step-num mono">01</div>
          <div>
            <h3>Score the task</h3>
            <p>Assign C, I, R, K values (1–3) based on context, expected iteration, review need, and deployment risk.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num mono">02</div>
          <div>
            <h3>Apply execution rules</h3>
            <p>The CIRK vector maps to an execution mode: autonomous, guided, draft-first, supervised, or blocked.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num mono">03</div>
          <div>
            <h3>Execute with governance</h3>
            <p>Agents act within defined boundaries. Humans intervene at declared checkpoints. Deployments follow explicit policies.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EXECUTION MAPPING -->
  <section class="section" id="execution">
    <div class="container">
      <p class="label mono">Execution mapping</p>
      <h2>CIRK as policy-as-code.</h2>
      <p class="section-sub">The vector defines what happens — not just how big the task is.</p>

      <div class="exec-grid">
        <div class="exec-card">
          <div class="exec-mode mono">Autonomous</div>
          <div class="exec-condition mono">Score 4–5 · R1</div>
          <p>Agent executes without intervention. Auto-approval allowed. No checkpoints.</p>
        </div>
        <div class="exec-card">
          <div class="exec-mode mono">Guided</div>
          <div class="exec-condition mono">Score 6–9</div>
          <p>Agent executes. Human review required before merge.</p>
        </div>
        <div class="exec-card">
          <div class="exec-mode mono">Draft-First</div>
          <div class="exec-condition mono">I3 or R3</div>
          <p>Agent produces a draft. Human validates before any commit.</p>
        </div>
        <div class="exec-card">
          <div class="exec-mode mono">Supervised</div>
          <div class="exec-condition mono">Score ≥ 10 · K3</div>
          <p>Step-by-step execution. Approval per step. Deploy runbook required.</p>
        </div>
        <div class="exec-card blocked">
          <div class="exec-mode mono">Blocked</div>
          <div class="exec-condition mono">Score = 12</div>
          <p>Task must be decomposed. Execution not allowed.</p>
        </div>
      </div>

      <div class="policy-rules">
        <p class="label mono">Policy rules</p>
        <div class="rule-row"><span class="mono rule-signal">I3</span><span>Draft-first required</span></div>
        <div class="rule-row"><span class="mono rule-signal">R3</span><span>Auto-approval disabled</span></div>
        <div class="rule-row"><span class="mono rule-signal">K3</span><span>Deploy runbook required</span></div>
      </div>
    </div>
  </section>

  <!-- EXAMPLES -->
  <section class="section alt-section" id="examples">
    <div class="container narrow">
      <p class="label mono">Examples</p>
      <h2>CIRK in practice.</h2>
      <p class="section-sub">Each vector maps to a concrete execution behavior.</p>

      <div class="examples-list">

        <div class="example-item">
          <div class="ex-header">
            <span class="ex-vector mono">C1 I1 R1 K2</span>
            <span class="ex-score mono">→ 5</span>
            <span class="badge trivial">Trivial</span>
          </div>
          <p class="ex-task">Add field to model</p>
          <div class="ex-behavior">
            <span class="ex-b-item ok">✓ Autonomous execution</span>
            <span class="ex-b-item ok">✓ Auto-approval allowed</span>
            <span class="ex-b-item ok">✓ No checkpoints required</span>
          </div>
        </div>

        <div class="example-item">
          <div class="ex-header">
            <span class="ex-vector mono">C2 I1 R2 K2</span>
            <span class="ex-score mono">→ 7</span>
            <span class="badge simple">Simple</span>
          </div>
          <p class="ex-task">New API endpoint</p>
          <div class="ex-behavior">
            <span class="ex-b-item ok">✓ Agent executes</span>
            <span class="ex-b-item warn">⚠ Human review before merge</span>
            <span class="ex-b-item warn">⚠ No auto-merge</span>
          </div>
        </div>

        <div class="example-item">
          <div class="ex-header">
            <span class="ex-vector mono">C2 I2 R3 K1</span>
            <span class="ex-score mono">→ 8</span>
            <span class="badge medium">Medium</span>
          </div>
          <p class="ex-task">Business logic change</p>
          <div class="ex-behavior">
            <span class="ex-b-item warn">⚠ Draft-first required (R3)</span>
            <span class="ex-b-item warn">⚠ Deep review mandatory</span>
            <span class="ex-b-item warn">⚠ Auto-approval disabled</span>
          </div>
        </div>

        <div class="example-item">
          <div class="ex-header">
            <span class="ex-vector mono">C3 I2 R3 K2</span>
            <span class="ex-score mono">→ 10</span>
            <span class="badge complex">Complex</span>
          </div>
          <p class="ex-task">Approval system</p>
          <div class="ex-behavior">
            <span class="ex-b-item block">✕ Supervised execution</span>
            <span class="ex-b-item block">✕ Approval per step</span>
            <span class="ex-b-item block">✕ Architect sign-off required</span>
          </div>
        </div>

        <div class="example-item">
          <div class="ex-header">
            <span class="ex-vector mono">C3 I2 R3 K3</span>
            <span class="ex-score mono">→ 11</span>
            <span class="badge complex">Complex</span>
          </div>
          <p class="ex-task">Cross-system auth change</p>
          <div class="ex-behavior">
            <span class="ex-b-item block">✕ Supervised execution</span>
            <span class="ex-b-item block">✕ Coordinated deployment required (K3)</span>
            <span class="ex-b-item block">✕ Deploy runbook mandatory</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- OPEN STANDARD -->
  <section class="section">
    <div class="container narrow center">
      <p class="label mono">Open standard</p>
      <h2>CIRK is not a product.</h2>
      <p class="section-sub">
        It is an open standard for execution governance in AI-native software development.
      </p>
      <p class="open-body">
        It can be adopted in issue trackers, coding agents, pull request workflows,
        internal platforms, or governance layers such as
        <a href="https://orbit618.com" target="_blank" rel="noopener">Orbit618</a>.
      </p>
      <div class="open-grid">
        <div class="open-card">Issue trackers</div>
        <div class="open-card">AI coding agents</div>
        <div class="open-card">PR workflows</div>
        <div class="open-card">Internal platforms</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container narrow center">
      <h2>Start using CIRK today.</h2>
      <p class="section-sub">MIT licensed. No dependencies. Works with anything.</p>
      <div class="hero-cta">
        <a href="https://github.com/core-618/cirk" class="btn-primary" target="_blank" rel="noopener">Read the spec →</a>
        <a href="#examples" class="btn-ghost">View quick examples</a>
        <a href="https://github.com/core-618/cirk" class="btn-ghost" target="_blank" rel="noopener">Open GitHub</a>
      </div>
    </div>
  </section>

  <!-- FOOTER TAGLINE -->
  <div class="footer-tagline">
    <div class="container">
      <span class="mono">AI writes the code. CIRK governs the execution.</span>
    </div>
  </div>

  <!-- FOOTER -->
  <footer>
    <div class="container footer-inner">
      <span class="mono footer-logo">CIRK</span>
      <span class="footer-meta">MIT License · <a href="https://github.com/core-618/cirk" target="_blank" rel="noopener">GitHub</a> · <a href="mailto:hello@core618.com">hello@core618.com</a></span>
      <span class="footer-meta">A standard by <a href="https://core618.com" target="_blank" rel="noopener">Core618</a></span>
    </div>
  </footer>
</Layout>

<style>
  /* ── Nav ── */
  nav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(17,17,17,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    max-width: 1100px; margin: 0 auto; padding: 0 24px;
    height: 56px; display: flex; align-items: center; justify-content: space-between;
  }
  .nav-logo { font-size: 14px; font-weight: 500; color: var(--text); letter-spacing: 0.08em; }
  .nav-links { display: flex; gap: 28px; }
  .nav-links a { font-size: 13px; color: var(--text-muted); transition: color 0.15s; }
  .nav-links a:hover { color: var(--text); text-decoration: none; }

  /* ── Layout ── */
  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  .container.narrow { max-width: 760px; }
  .container.center { text-align: center; }
  .section { padding: 96px 0; }
  .alt-section { background: var(--bg-container); }

  /* ── Hero ── */
  .hero { padding: 120px 0 96px; }
  .hero-status {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--green); background: var(--green-dim);
    border: 1px solid rgba(16,185,129,0.25);
    border-radius: 20px; padding: 5px 14px; margin-bottom: 32px;
  }
  .hero-status-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--green); flex-shrink: 0;
    box-shadow: 0 0 6px var(--green);
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 500;
    line-height: 1.15; letter-spacing: -0.02em; margin-bottom: 20px; color: var(--text);
  }
  .hero-clarify {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--text-muted);
    font-weight: 400;
    margin-bottom: 36px;
    line-height: 1.5;
  }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn-primary {
    display: inline-flex; align-items: center; padding: 10px 20px;
    background: var(--accent); color: #fff; border-radius: var(--radius-sm);
    font-size: 14px; font-weight: 500; transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.85; text-decoration: none; }
  .btn-ghost {
    display: inline-flex; align-items: center; padding: 10px 20px;
    background: transparent; color: var(--text-muted);
    border: 1px solid var(--border); border-radius: var(--radius-sm);
    font-size: 14px; font-weight: 500; transition: border-color 0.15s, color 0.15s;
  }
  .btn-ghost:hover { border-color: var(--border-hover); color: var(--text); text-decoration: none; }

  /* ── Typography ── */
  .label {
    font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--text-secondary); margin-bottom: 16px; display: block;
  }
  h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 500;
    letter-spacing: -0.02em; line-height: 1.2; margin-bottom: 8px;
  }
  h3 { font-size: 1rem; font-weight: 500; margin-bottom: 8px; }
  .accent { color: var(--accent); }
  .section-sub {
    font-size: 1rem; color: var(--text-muted); margin-top: 12px;
    margin-bottom: 48px; line-height: 1.7;
  }

  /* ── Shift ── */
  #why .container { text-align: right; }
  .shift-sub { font-size: 1rem; color: var(--text-muted); margin: 16px 0 20px; line-height: 1.7; text-align: right; }
  .shift-list {
    list-style: none; display: flex; flex-direction: column; gap: 10px;
    margin-bottom: 28px; text-align: right;
  }
  .shift-list li { font-size: 15px; color: var(--text); }
  .shift-list li::before { content: none; }
  .shift-close { font-size: 1.125rem; font-weight: 500; color: var(--accent); text-align: right; }

  /* ── Model ── */
  .model-formula { font-size: clamp(1.5rem, 4vw, 2.5rem); color: var(--text-secondary); margin: 40px 0 48px; letter-spacing: 0.1em; }
  .dimensions-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; margin-bottom: 64px; }
  .dim-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 28px 24px; }
  .dim-letter { font-family: var(--font-mono); font-size: 2rem; font-weight: 500; margin-bottom: 8px; }
  .dim-card > p { font-size: 13px; color: var(--text-muted); margin-bottom: 16px; }
  .dim-card table { width: 100%; border-collapse: collapse; }
  .dim-card td { font-size: 13px; padding: 5px 0; vertical-align: top; }
  .dim-card td:first-child { color: var(--text-secondary); width: 32px; padding-right: 8px; }
  .dim-card td:last-child { color: var(--text-muted); }

  /* ── Score table ── */
  .score-table-wrap { background: var(--bg-container); border: 1px solid var(--border); border-radius: var(--radius); padding: 32px; }
  .score-table { display: flex; flex-direction: column; gap: 2px; }
  .score-row { display: flex; align-items: center; gap: 16px; padding: 12px 0; border-bottom: 1px solid var(--border); }
  .score-row:last-child { border-bottom: none; }
  .score-range { min-width: 44px; color: var(--text-secondary); font-size: 13px; }
  .score-note { font-size: 13px; color: var(--text-muted); }
  .score-note-footer { margin-top: 20px; font-size: 13px; color: var(--text-secondary); font-style: italic; line-height: 1.5; }

  /* ── Badges ── */
  .badge {
    font-family: var(--font-mono); font-size: 11px; padding: 2px 10px;
    border-radius: 20px; white-space: nowrap; flex-shrink: 0;
  }
  .badge.trivial { background: var(--green-dim);  color: var(--green);   border: 1px solid rgba(16,185,129,0.2); }
  .badge.simple  { background: var(--accent-dim); color: var(--accent);  border: 1px solid var(--accent-border); }
  .badge.medium  { background: var(--amber-dim);  color: var(--amber);   border: 1px solid rgba(245,158,11,0.2); }
  .badge.complex { background: rgba(239,68,68,0.1); color: #ef4444;      border: 1px solid rgba(239,68,68,0.2); }
  .badge.split   { background: rgba(139,92,246,0.1); color: var(--purple); border: 1px solid rgba(139,92,246,0.2); }

  /* ── Story contrast ── */
  .story-contrast {
    margin: 0 0 32px;
    padding: 20px 24px;
    background: var(--bg-container);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    max-width: 600px;
  }
  .story-contrast p:first-child { font-size: 1.125rem; font-weight: 500; line-height: 1.4; }
  .contrast-old { color: var(--text-secondary); text-decoration: line-through; text-decoration-color: var(--border-hover); }
  .contrast-new { color: var(--accent); }
  .contrast-sub { font-size: 14px; color: var(--text-muted); margin-top: 8px; }

  /* ── Model consequence ── */
  .model-consequence {
    margin: 0 0 48px;
    padding: 20px 24px;
    border-left: 2px solid var(--accent);
    background: var(--accent-dim);
    border-radius: 0 var(--radius) var(--radius) 0;
    max-width: 600px;
  }
  .model-consequence-title { font-size: 14px; color: var(--text); margin-bottom: 12px; line-height: 1.5; }
  .model-consequence ul { list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .model-consequence li { font-size: 14px; color: var(--text-muted); padding-left: 16px; position: relative; }
  .model-consequence li::before { content: '→'; position: absolute; left: 0; color: var(--accent); }

  /* ── Inline example ── */
  .inline-example {
    margin-top: 40px;
    padding: 24px 28px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    max-width: 480px;
  }
  .inline-ex-vector { font-size: 1.125rem; font-weight: 500; color: var(--text); margin-bottom: 16px; }
  .inline-ex-score { color: var(--text-secondary); font-weight: 400; }
  .inline-ex-rules { display: flex; flex-wrap: wrap; gap: 8px; }

  /* ── Steps ── */
  .steps { display: flex; flex-direction: column; gap: 0; margin-top: 40px; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .step { display: flex; align-items: flex-start; gap: 24px; padding: 28px 28px; background: var(--bg-card); border-bottom: 1px solid var(--border); }
  .step:last-child { border-bottom: none; }
  .step-num { font-size: 1.5rem; font-weight: 500; color: var(--accent); min-width: 36px; line-height: 1.3; }
  .step h3 { margin-bottom: 6px; }
  .step p { font-size: 14px; color: var(--text-muted); line-height: 1.6; }

  /* ── Execution ── */
  .exec-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; margin-bottom: 48px; }
